# Сервис
NERFORGE_SERVICE_NAME=NERForge
NERFORGE_SERVICE_VERSION=0.1.0

# PostgreSQL
NERFORGE_DATABASE_USER=nerforge
NERFORGE_DATABASE_PASSWORD=nerforge
NERFORGE_DATABASE_HOST=postgres
NERFORGE_DATABASE_PORT=5432
NERFORGE_DATABASE_NAME=nerforge

# RabbitMQ
NERFORGE_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
NERFORGE_RABBITMQ_VIRTUAL_HOST=/
NERFORGE_RABBITMQ_PREFETCH_COUNT=1
NERFORGE_RABBITMQ_TRAINING_QUEUE=nerforge.training

# Хранилище артефактов
NERFORGE_DATA_DIR=/app/data
