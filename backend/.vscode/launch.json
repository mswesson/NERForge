{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NERForge backend (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "src.main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "NERFORGE_SERVICE_NAME": "NERForge",
        "NERFORGE_SERVICE_VERSION": "0.1.0",
        "NERFORGE_DATA_DIR": "${workspaceFolder}/data",
        "NERFORGE_CORS_ORIGINS": "[\"http://localhost:3000\"]"
      }
    }
  ]
}
